{
  "manifest_version": 3,
  "name": "ds-chat2api Data Collector",
  "version": "1.0.0",
  "description": "WebSocket-controlled data collection tool for targeted web pages",
  "permissions": ["debugger", "storage", "tabs", "scripting"],
  "host_permissions": ["https://chat.deepseek.com/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chat.deepseek.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "ds-chat2api Data Collector",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon-16x16.png",
    "48": "icons/icon-48x48.png",
    "128": "icons/icon-128x128.png"
  }
}
